{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "autoupdate": true,
  "default_agent": "King of the wire throne",
  "agent": {
    "build": {
      "color": "#c099ff",
      "permission": {
        "bash": {
          "git *": "ask",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "gh *": "ask",
          "rm *": "ask"
        },
        "task": {
          "code-checker": "allow",
        }
      }
    },
    "plan": {
      "color": "#ff966c",
      "permission": {
        "bash": {
          "*": "ask",
          "cat *": "allow",
          "echo *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "ls *": "allow",
          "* tsc *": "allow"
        }
      }
    }
  },
  "mcp": {
    "browsermcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browsermcp/mcp@latest",
      ],
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
      ],
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "grep-app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "next-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "webmcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@jason.today/webmcp@latest",
        "--mcp"
      ]
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
  }
}
